SECRET_KEY=
DEBUG=False

# Homologacao / DEV
DEV_POSTGRES_DB=relatorios_dev
DEV_POSTGRES_USER=app_relatorios_user
DEV_POSTGRES_PASSWORD=
DEV_POSTGRES_HOST=127.0.0.1
DEV_POSTGRES_PORT=5432
DEV_POSTGRES_CONN_MAX_AGE=0

# Producao
DATABASE_URL=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
POSTGRES_DB=app_relatorios
POSTGRES_USER=app_relatorios_user
POSTGRES_PASSWORD=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# LDAP / Active Directory
LDAP_AUTH_ENABLED=False
LDAP_SERVER_URI=
LDAP_SERVER_URIS=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_SEARCH_BASE=
LDAP_USER_SEARCH_BASE_DN=
LDAP_USER_SEARCH_FILTER=(sAMAccountName=%(user)s)
LDAP_GROUP_SEARCH_BASE=
LDAP_GROUP_SEARCH_BASE_DN=
LDAP_GROUP_SEARCH_FILTER=(objectClass=group)
LDAP_REQUIRE_GROUP=
LDAP_ACTIVE_DIRECTORY_DOMAIN=
LDAP_START_TLS=False
LDAP_DISABLE_REFERRALS=True
LDAP_NETWORK_TIMEOUT=5
LDAP_OPERATION_TIMEOUT=10
LDAP_NORMALIZE_USERNAME=True
LDAP_TLS_REQUIRE_CERT=DEMAND
LDAP_CA_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
LDAP_CA_CERT_DIR=
LDAP_USER_EXISTS_CACHE_TIMEOUT=300
LDAP_DIRECTORY_CACHE_TIMEOUT=300
LDAP_SESSION_REVALIDATE_SECONDS=300
LDAP_BLOCK_USERS_WITHOUT_ERP_GROUP=True
AD_GROUP_MAPPING={}
AD_SYNC_ENABLED=True
AD_USERS_BASE_DN=
AD_USERS_FILTER=(&(objectClass=user)(!(userAccountControl:1.2.840.113556.1.4.803:=2)))

# Sessao/cache
SESSION_COOKIE_AGE=3600
SESSION_SAVE_EVERY_REQUEST=True
SESSION_EXPIRE_AT_BROWSER_CLOSE=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=SAMEORIGIN
SECURE_REFERRER_POLICY=same-origin
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
CACHE_LOCATION=erp-relatorios-cache
DASHBOARD_CACHE_TTL=180

# Logs técnicos
APP_LOG_DIR=/home/app_relatorios_logs
APP_LOG_LEVEL=INFO
ANEXO_MAX_UPLOAD_MB=10
HELP_IMAGES_ROOT=/home/app_relatorios_files/help_images
HELP_IMAGES_MAX_UPLOAD_MB=5
ANEXOS_ROOT=/home/app_relatorios_files
ANEXOS_URL=/anexos/
VALOR_KM_CONTROLSUL=1.35
BACKUP_DIR=/home/app_relatorios_backups

# Sincronizacao de clientes ControlSul
CLIENTES_API_URL=https://api.controlsul.com/clients
CLIENTES_API_TOKEN=
CLIENTES_API_TIMEOUT=30
CLIENTES_API_ENABLED=True

# Email / SMTP interno
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=15
DEFAULT_FROM_EMAIL=
APP_BASE_URL=
FINANCEIRO_EMAIL=financeiro@controlsul.com.br
EMAIL_DESTINATARIOS_FINALIZACAO_EXTRA=
