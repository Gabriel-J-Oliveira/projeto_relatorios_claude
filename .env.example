SECRET_KEY=troque-esta-chave

# Homologacao / DEV
DEV_POSTGRES_DB=relatorios_dev
DEV_POSTGRES_USER=app_relatorios_user
DEV_POSTGRES_PASSWORD=preencha-a-senha
DEV_POSTGRES_HOST=192.168.106.51
DEV_POSTGRES_PORT=5432

# Producao
POSTGRES_DB=app_relatorios
POSTGRES_USER=app_relatorios_user
POSTGRES_PASSWORD=preencha-a-senha
POSTGRES_HOST=192.168.106.51
POSTGRES_PORT=5432

ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# LDAP / Active Directory
LDAP_AUTH_ENABLED=False
LDAP_SERVER_URI=ldap://dc01.seu-dominio.local:389
LDAP_SERVER_URIS=ldap://dc01.seu-dominio.local:389,ldap://dc02.seu-dominio.local:389
LDAP_BIND_DN=CN=usuario-bind,OU=UsuariosServico,DC=seu-dominio,DC=local
LDAP_BIND_PASSWORD=preencha-a-senha
LDAP_USER_SEARCH_BASE_DN=DC=seu-dominio,DC=local
LDAP_USER_SEARCH_FILTER=(sAMAccountName=%(user)s)
LDAP_GROUP_SEARCH_BASE_DN=OU=Grupos,DC=seu-dominio,DC=local
LDAP_GROUP_SEARCH_FILTER=(objectClass=group)
LDAP_REQUIRE_GROUP=
LDAP_ACTIVE_DIRECTORY_DOMAIN=
LDAP_START_TLS=False
LDAP_DISABLE_REFERRALS=True
LDAP_NETWORK_TIMEOUT=5
LDAP_OPERATION_TIMEOUT=10
LDAP_NORMALIZE_USERNAME=True
LDAP_TLS_REQUIRE_CERT=DEMAND
LDAP_CA_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
LDAP_CA_CERT_DIR=
AD_GROUP_MAPPING={"CN=ERP-Financeiro,OU=Grupos,DC=seu-dominio,DC=local":"Financeiro","CN=ERP-Tecnicos,OU=Grupos,DC=seu-dominio,DC=local":"Tecnico","CN=ERP-Gestores,OU=Grupos,DC=seu-dominio,DC=local":"Gestor","CN=ERP-Admins,OU=Grupos,DC=seu-dominio,DC=local":"Administrador ERP"}
