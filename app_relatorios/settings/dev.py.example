"""
Exemplo de settings de homologação/desenvolvimento.

Copie para app_relatorios/settings/dev.py no servidor/ambiente local e configure
as variáveis no .env. Não versione dev.py real.
"""

from .base import *  # noqa

DEBUG = True
ALLOWED_HOSTS = ["*"]

DATABASES = {
    "default": {
        "ENGINE": "django.db.backends.postgresql",
        "NAME": config("DEV_POSTGRES_DB", default="relatorios_dev"),
        "USER": config("DEV_POSTGRES_USER", default="app_relatorios_user"),
        "PASSWORD": config("DEV_POSTGRES_PASSWORD"),
        "HOST": config("DEV_POSTGRES_HOST", default="127.0.0.1"),
        "PORT": config("DEV_POSTGRES_PORT", default="5432"),
        "CONN_MAX_AGE": config("DEV_POSTGRES_CONN_MAX_AGE", default=0, cast=int),
    }
}

STATICFILES_DIRS = [BASE_DIR / "static"]
STATIC_ROOT = BASE_DIR / "staticfiles"

EMAIL_BACKEND = "django.core.mail.backends.console.EmailBackend"
